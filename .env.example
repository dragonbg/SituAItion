# ── Backend selection ──────────────────────────────────────────
# Options: ollama | groq
SITUAITION_BACKEND=groq

# ── Model ──────────────────────────────────────────────────────
# Groq models (pick one):
#   llama-3.3-70b-versatile   ← smarter, still fast
#   llama-3.1-8b-instant      ← fastest, lower quality
SITUAITION_MODEL=llama-3.3-70b-versatile

# ── Groq API key ───────────────────────────────────────────────
# Get free key at: console.groq.com
GROQ_API_KEY=your_key_here

# ── Ollama (only needed if SITUAITION_BACKEND=ollama) ──────────
# SITUAITION_MODEL=qwen3:8b
# SITUAITION_TIMEOUT_S=90
OLLAMA_NUM_PARALLEL=1
